<div class="card mb-3 shadow-sm">
  <div class="card-body d-flex justify-content-between align-items-center">

    <div class="d-flex align-items-center">
      <div class="me-3">
        <% if result.profile_image.attached? %>
          <%= image_tag result.profile_image, size: "60x60", class: "rounded-circle object-fit-cover" %>
        <% else %>
          <%= image_tag "default-image.png", size: "60x60", class: "rounded-circle" %>
        <% end %>
      </div>

      <h5 class="mb-1 fw-bold"><%= result.name %></h5>
    </div>

    <%= link_to "詳細を見る", user_path(result), class: "btn btn-sm btn-primary" %>

  </div>
</div>